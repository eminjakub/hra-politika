<Page x:Class="game.Most"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:game"
      mc:Ignorable="d" 
      d:DesignHeight="720" d:DesignWidth="1280"
      Title="most">

    <Grid>
        <Image Stretch="Fill" Source="./fotky/most.png"/>
        <Button HorizontalAlignment="Center" Margin="0,296,0,0" VerticalAlignment="Top" Height="202" Width="210" Background="{x:Null}" Foreground="{x:Null}" BorderBrush="{x:Null}" RenderTransformOrigin="0.277,0.386" Click="dealeros_button_click_shop">
            <Image x:Name="dealeros_velky_img"  Visibility="Visible" Height="192" Stretch="Fill" Source="./fotky/dealeros_postava_velka.png" Width="198" RenderTransformOrigin="0.5,0.5"/>
        </Button>

        <TextBlock x:Name="dealeros_window" Visibility="Hidden" HorizontalAlignment="Center" Text="TextBlock" TextWrapping="Wrap" VerticalAlignment="Center" Height="492" Width="964" Background="#FF404040" Opacity="0.75"/>
        <Image x:Name="dealeros_img" Visibility="Hidden" Margin="201,212,823,252" Stretch="Fill" Source="./fotky/dealeros.png"/>
        <Image x:Name="dealeros_frame" Visibility="Hidden" Margin="-35,10,-102,10" Stretch="Fill" Source="./fotky/frame_dealeros.png"/>
        

        <Button x:Name="dealeros_close_button" HorizontalAlignment="Left" Margin="1079,539,0,0" VerticalAlignment="Top" Height="67" Width="70" Background="{x:Null}" BorderBrush="{x:Null}" Click="dealeros_button_click_close" Foreground="{x:Null}">
            <Image x:Name="dealeros_close_button_img"  Visibility="Hidden" Height="57" Stretch="Fill" Source="./fotky/close_button.png" Width="60"/>
        </Button>
        <Button Click="Get_home" HorizontalAlignment="Left" Margin="10,10,0,0" VerticalAlignment="Top" Height="72" Width="77">
            <Image Height="72" Source="/fotky/home_button.png" Stretch="Fill" Width="67"/>
        </Button>
    </Grid>
</Page>
