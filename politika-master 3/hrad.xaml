<Page x:Class="game.Hrad"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:game"
      mc:Ignorable="d" 
      d:DesignHeight="720" d:DesignWidth="1280"
      Title="hrad">

    <Canvas>
        <Image Height="720" Stretch="Fill" Source="./fotky/hrad.png" Width="1280"/>



        <Button x:Name="milos_button" Canvas.Left="500" Canvas.Top="360" RenderTransformOrigin="0.5,0.5" Height="255" Width="280" BorderThickness="0,0,0,0" Background="{x:Null}" BorderBrush="{x:Null}" Click="Button_Click" Visibility="Visible">
            <Image x:Name="milos_button_img" Height="174" Stretch="Fill" Source="./fotky/Milos_akavrko.jpg" Width="208" RenderTransformOrigin="0.922,0.949"/>
        </Button>




        <TextBlock x:Name="quest_box" Canvas.Left="239" Canvas.Top="275" TextWrapping="Wrap" Height="359" Width="768" Background="#FFCBCBCB" RenderTransformOrigin="0.5,0.5" Opacity="0.75" Visibility="Hidden">
            <TextBlock.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform AngleX="-1.204"/>
                    <RotateTransform/>
                    <TranslateTransform X="-3.479"/>
                </TransformGroup>
            </TextBlock.RenderTransform>
        </TextBlock>
        <Image x:Name="quest_milos" Height="218" Canvas.Left="252" Stretch="Fill" Source="./fotky/Milos.png" Canvas.Top="337" Width="243" Visibility="Hidden"/>
        <Image x:Name="frame" Height="564" Canvas.Left="205" Stretch="Fill" Source="./fotky/frame.png" Canvas.Top="170" Width="825" Visibility="Hidden"/>
        <Button x:Name="close_button" Canvas.Left="942" Canvas.Top="579" Height="36" Width="46" Background="{x:Null}" BorderBrush="{x:Null}" Foreground="{x:Null}" Click="milos_quest_close" Visibility="Hidden">
            <Image x:Name="close_button_img" Height="31" Stretch="Fill" Source="./fotky/close_button.png" Width="38" Visibility="Hidden"/>
        </Button>
        <Button x:Name="task_1" Canvas.Left="551" Canvas.Top="347" Height="208" Width="338" Click="Button_Click_2" Visibility="Hidden" HorizontalAlignment="Center" VerticalAlignment="Top" Background="#FFC8C8C8" BorderBrush="White" Foreground="{x:Null}"/>
        <Label x:Name="task_name_label" Content="Nazev tasku" Canvas.Left="578" Canvas.Top="363" Visibility="Hidden" FontFamily="Viner Hand ITC" Height="39" Width="325" HorizontalAlignment="Left" VerticalAlignment="Top" FontSize="20"/>


        <Label x:Name="task_lenght_label" Content="Delka tasku" Canvas.Left="564" Canvas.Top="508" Visibility="Hidden" HorizontalAlignment="Left" VerticalAlignment="Top" FontFamily="Viner Hand ITC" FontSize="20"/>
        <Label x:Name="task_money_label" Visibility="Hidden" Content="Penize" Canvas.Left="766" Canvas.Top="509" FontFamily="Viner Hand ITC" HorizontalAlignment="Left" VerticalAlignment="Center" Width="112" FontSize="20" Height="31"/>
        <Button Canvas.Left="10" Canvas.Top="10" Height="79" Width="78" HorizontalAlignment="Left" VerticalAlignment="Top" Click="get_home" Background="{x:Null}" BorderBrush="{x:Null}">
            <Image Height="69" Source="/fotky/home_button.png" Stretch="Fill" Width="68"/>
        </Button>
        <TextBlock x:Name="task_description_label" Visibility="Hidden" Canvas.Left="604" TextWrapping="Wrap" Canvas.Top="407" Height="102" Width="236" FontFamily="Viner Hand ITC" FontSize="15"><Run Language="cs-cz" Text="Nejaky text"/><LineBreak/><Run Language="cs-cz"/></TextBlock>


    </Canvas>
</Page>
