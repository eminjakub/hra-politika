<Page x:Class="game.Arena"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:game"
      mc:Ignorable="d" 
      d:DesignHeight="720" d:DesignWidth="1280"
      Title="Arena"  Height="720" Width="1280">

    <Grid>
        <Image Source="./fotky/arena.jpg" Stretch="Fill"/>
        <Button x:Name="flakanec_img_postava" Visibility="Visible" Margin="212,227,793,291" Click="Arena_button" BorderBrush="{x:Null}" Background="{x:Null}" Foreground="{x:Null}">
            <Image Height="192" Source="/fotky/flakanec_postava.png" Stretch="Fill" Width="256"/>
        </Button>



        <TextBlock x:Name="flakanec_block" Visibility="Hidden" HorizontalAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Center" Height="378" Width="856" Background="#FF5B5B5B" Foreground="#FF080808" Opacity="0.8"/>
        <Image x:Name="flakanec_img" Visibility="Hidden" Margin="251,237,685,246" Source="./fotky/flakanec.png" Stretch="Fill"/>
        <TextBlock x:Name="dialog_block" Visibility="Hidden" HorizontalAlignment="Left" Margin="626,239,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Height="194" Width="427" FontFamily="Viner Hand ITC" Foreground="White" FontSize="20"><Run Text="Hele? To čumíš na mě?"/><Run Language="cs-cz" Text=" Chceš flákanec?"/><LineBreak/><Run Language="cs-cz" Text="Já jsem občany volený zástupce lidu!!"/><LineBreak/><Run Language="cs-cz" Text="Jestli tady půjdeš, dostaneš FLÁKANEC."/><LineBreak/><Run Language="cs-cz"/><LineBreak/><Run Language="cs-cz" Text="Takže já jsem tě varoval!"/></TextBlock>
        <Button x:Name="start_fight" Visibility="Hidden" Content="Začít fight" HorizontalAlignment="Left" Margin="763,451,0,0" VerticalAlignment="Top" Height="73" Width="167" Click="Fight_start" FontFamily="Viner Hand ITC" FontSize="25"/>
        <Button x:Name="dialog_close" Visibility="Hidden" HorizontalAlignment="Left" Margin="983,484,0,0" VerticalAlignment="Top" Height="56" Width="70" Click="Dialog_close" BorderBrush="{x:Null}" Background="#FFB1B0B0" Foreground="White">
            <Image Height="39" Source="/fotky/close_button.png" Stretch="Fill" Width="41"/>
        </Button>
        <TextBlock x:Name="dialog_after" Visibility="Hidden" HorizontalAlignment="Left" Margin="657,237,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Height="237" Width="396" Foreground="#FFFFFBFB" FontSize="25" FontFamily="Viner Hand ITC"><Run Language="cs-cz" Text="TEXT"/></TextBlock>
        <Image x:Name="flakanec_ruka" Visibility="Hidden" Margin="454,316,532,186" Source="/fotky/flakanec_ruka.png" Stretch="Fill" RenderTransformOrigin="0.5,0.5">
            <Image.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform/>
                    <RotateTransform Angle="-29.362"/>
                    <TranslateTransform/>
                </TransformGroup>
            </Image.RenderTransform>
        </Image>
        <Button Click="Get_home" HorizontalAlignment="Left" Margin="10,10,0,0" VerticalAlignment="Top" Height="87" Width="88" Background="{x:Null}" BorderBrush="{x:Null}">
            <Image Height="77" Source="/fotky/home_button.png" Stretch="Fill" Width="78"/>
        </Button>




    </Grid>
</Page>
