<Page x:Class="game.Mainmenu"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:game"
      mc:Ignorable="d" 
      d:DesignHeight="720" d:DesignWidth="1280"
      Title="mainmenu"  Height="720" Width="1280">

    <Grid>

        <Image Stretch="Fill" Source=".\fotky\bgame.png" Height="720" Width="1280"/>

        <Canvas>

            <Button Canvas.Left="640" Canvas.Top="156" Height="126" Width="362" Click="hrad_move" Background="#FFA4A4A4" Foreground="{x:Null}" BorderBrush="#FF8C8C8C" HorizontalAlignment="Left" VerticalAlignment="Top" Opacity="0.3">

            </Button>

            <Button Canvas.Left="1052" Canvas.Top="522" Height="144" Width="218" Click="Button_Click_1" Background="#FFA4A4A4" Foreground="{x:Null}" BorderBrush="#FF8C8C8C" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.3">

            </Button>
            <Button Canvas.Left="464" Canvas.Top="522" Height="126" Width="208" Click="obchod_move" Background="#FFA4A4A4" Foreground="{x:Null}" BorderBrush="#FF8C8C8C" HorizontalAlignment="Left" VerticalAlignment="Top" Opacity="0.3"/>


            <Button Canvas.Left="10" Canvas.Top="650" Height="60" Width="63" HorizontalAlignment="Left" VerticalAlignment="Top" Click="home_exit" Background="{x:Null}" BorderBrush="{x:Null}">
                <Image Height="60" Source="./fotky/save.png" Stretch="Fill" Width="63"/>
            </Button>
            <TextBlock TextWrapping="Wrap" Height="121" Width="228" Background="#FF828282" Foreground="{x:Null}" HorizontalAlignment="Left" Canvas.Left="1052" VerticalAlignment="Top"/>

            <ProgressBar x:Name="exp_bar_menu" Height="16" Width="207" HorizontalAlignment="Left" Canvas.Left="1063" Canvas.Top="94" VerticalAlignment="Top" Foreground="#FF007DCC" Value="90"/>
            <Label Content="Level" RenderTransformOrigin="1.329,0.327" HorizontalAlignment="Left" Canvas.Left="1063" Canvas.Top="60" VerticalAlignment="Top" FontFamily="Viner Hand ITC" FontSize="20"/>
            <Label x:Name="label_money" Content="0" HorizontalAlignment="Left" Canvas.Left="1166" VerticalAlignment="Center" FontFamily="Viner Hand ITC" FontSize="25" Height="42" Width="112" Canvas.Top="13"/>
            <Label x:Name="lv_status" Content="1" HorizontalAlignment="Left" Canvas.Left="1238" Canvas.Top="57" VerticalAlignment="Center" Height="33" Width="22" FontSize="25" FontFamily="Viner Hand ITC"/>
            <Image Height="82" Canvas.Left="1037" Source="/fotky/piggy_money.png" Stretch="Fill" Canvas.Top="-7" Width="113" HorizontalAlignment="Left" VerticalAlignment="Top"/>
            <Border BorderBrush="Black" BorderThickness="2
                    " Height="126" Canvas.Left="1052" Width="254" HorizontalAlignment="Left" VerticalAlignment="Top" Canvas.Top="-5"/>

            <Button Canvas.Left="108" Canvas.Top="267" Height="132" Width="171" Click="Arena_button" Background="#FFA4A4A4" Foreground="{x:Null}" BorderBrush="#FF8C8C8C" HorizontalAlignment="Left" VerticalAlignment="Top" Opacity="0.3"/>

            <Image Source="./fotky/taska.png" Height="100" Width="94" Canvas.Left="1166" Canvas.Top="140"/>
            <Button Canvas.Top="140" Height="100" Width="93" Click="inventory_button_Click" Background="#FFA4A4A4" Foreground="{x:Null}" BorderBrush="#FF8C8C8C" HorizontalAlignment="Left" VerticalAlignment="Top" Opacity="0.01" Canvas.Left="1166"/>





        </Canvas>

        <TextBlock x:Name="inventory" HorizontalAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Center" Background="#FF8A8A8A" Height="432" Width="708" Opacity="0.9" Visibility="Hidden"><Run/><LineBreak/><Run/></TextBlock>
        <Label x:Name="inventory_name" Content="Profil&#xD;&#xA;" HorizontalAlignment="Center" Margin="0,157,0,0" VerticalAlignment="Top" Height="70" Width="138" FontSize="50" FontFamily="Viner Hand ITC" Visibility="Hidden"/>
        <Border x:Name="inventory_border" BorderBrush="Black" BorderThickness="3" Margin="553,248,553,304" Visibility="Hidden">
            <Image Margin="-33,-38,-33,0" Source="/fotky/profile_foto.png" Stretch="Fill" Height="200" VerticalAlignment="Top"/>
        </Border>
        <ProgressBar x:Name="progress_bar_strenght" HorizontalAlignment="Left" Height="23" Margin="382,503,0,0" VerticalAlignment="Top" Width="151" Value="1" Visibility="Hidden" Foreground="#FFDC0000"/>
        <ProgressBar x:Name="progress_bar_dexterity" HorizontalAlignment="Center" Height="23" Margin="0,503,0,0" VerticalAlignment="Top" Width="151" Value="1" Visibility="Hidden"/>
        <ProgressBar x:Name="progress_bar_armor" HorizontalAlignment="Left" Height="23" Margin="753,503,0,0" VerticalAlignment="Top" Width="151" Value="1" Visibility="Hidden" Foreground="#FFD4E000"/>

        <Label x:Name="strenght_name" Content="Strenght" HorizontalAlignment="Left" Margin="400,439,0,0" VerticalAlignment="Top" Visibility="Hidden" FontFamily="Viner Hand ITC" FontSize="25" />
        <Label x:Name="dexterity_name"  Content="Dexterity" HorizontalAlignment="Center" Margin="0,439,0,0" VerticalAlignment="Top" Visibility="Hidden" FontFamily="Viner Hand ITC" FontSize="25" />
        <Label x:Name="armor_name" Content="Armor" HorizontalAlignment="Left" Margin="788,444,0,0" VerticalAlignment="Top" Height="40" Visibility="Hidden" FontFamily="Viner Hand ITC" FontSize="25"/>
        <Button Click="save_button" HorizontalAlignment="Left" Margin="86,650,0,0" VerticalAlignment="Top" Height="60" Width="62" Background="{x:Null}" BorderBrush="{x:Null}">
            <Image Height="60" Source="./fotky/save_bt.png" Stretch="Fill" Width="52"/>
        </Button>
        <Button x:Name="inventory_close_bt" Visibility="Hidden" Click="close_bt"  HorizontalAlignment="Left" Margin="930,512,0,0" VerticalAlignment="Top" Height="60" Width="60" Background="{x:Null}" BorderBrush="{x:Null}">
            <Image Height="50" Source="/fotky/close_button.png" Stretch="Fill" Width="55"/>
        </Button>
        <Button x:Name="strengt_add_bt" Visibility="Hidden"  Click="strenght_add" Content="ADD strenght" HorizontalAlignment="Left" Margin="423,537,0,0" VerticalAlignment="Top" Height="25" Width="80"/>
        <Button x:Name="dexterity_add_bt" Visibility="Hidden" Click="dexterity_add" Content="ADD dexterity" HorizontalAlignment="Center" Margin="0,537,0,0" VerticalAlignment="Top" Height="25" Width="80"/>
        <Button x:Name="armor_add_bt" Visibility="Hidden" Click="armor_add" Content="ADD armor" HorizontalAlignment="Left" Margin="803,537,0,0" VerticalAlignment="Top" Height="25" Width="80"/>
        <TextBlock x:Name="achv" Visibility="Hidden" HorizontalAlignment="Left" TextWrapping="Wrap" VerticalAlignment="Top" Height="69" Width="201" Background="#FF424242" Foreground="White" FontFamily="Viner Hand ITC"><Run Text="      "/><Run Text="ACHIEVEMENT UNLOCKED"/><LineBreak/><Run Text=" "/><LineBreak/><Run Text="&#x9;Poraz pana Flákance"/></TextBlock>


    </Grid>
</Page>
