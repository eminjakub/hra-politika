<Page
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:game"
      xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation" x:Class="game.Obchod"
      mc:Ignorable="d" 
      d:DesignHeight="720" d:DesignWidth="1280"
      Title="Obchod" Height="720" Width="1280">

    <Grid>
        <Image Stretch="Fill" Source="./fotky/obchod.png" Margin="-15,0,0,0"/>
        <Button x:Name="zpevak_bt_action" HorizontalAlignment="Left" Margin="462,346,0,0" VerticalAlignment="Top" Height="120" Width="205" Background="{x:Null}" Foreground="{x:Null}" BorderBrush="{x:Null}" Click="zpevak_action" Visibility="Visible">
            <Image Height="109" Stretch="Fill" Source="./fotky/zpevak_velky.png" Width="176"/>
        </Button>
        <Button x:Name="obchod_in_bt" HorizontalAlignment="Left" Margin="934,316,0,0" VerticalAlignment="Top" Height="135" Width="146" Background="{x:Null}" BorderBrush="{x:Null}" Foreground="{x:Null}" Click="button_in_shop" Visibility="Visible">
            <Image Height="135" Stretch="Fill" Source="/fotky/arrow_in.png" Width="171" RenderTransformOrigin="0.068,0.567">
                <Image.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform/>
                        <SkewTransform AngleY="0"/>
                        <RotateTransform/>
                        <TranslateTransform Y="0"/>
                    </TransformGroup>
                </Image.RenderTransform>
            </Image>
        </Button>


        <TextBlock x:Name="zpevak_okno" HorizontalAlignment="Left" Margin="240,0,0,0" TextWrapping="Wrap" VerticalAlignment="Center" Height="464" Width="784" Background="#FFA4A4A4" Opacity="0.9" Visibility="Hidden"/>
        <Image x:Name="zpevak_img" Margin="255,232,769,232" Source="./fotky/zpevak.png" Stretch="Fill" Visibility="Hidden"/>

        <Button x:Name="zpevak_close_bt" HorizontalAlignment="Left" Margin="916,506,0,0" VerticalAlignment="Top" Height="66" Width="91" Click="zpevak_close" Visibility="Hidden">
            <Image Height="56" Source="/fotky/close_button.png" Stretch="Fill" Width="81"/>
        </Button>
        <TextBlock x:Name="zpevak_dialog" Visibility="Hidden" HorizontalAlignment="Left" Margin="564,260,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Height="227" Width="443" FontSize="25" FontFamily="Viner Hand ITC"><Run Text="To je hezké počasí že? Slyšel jsem, že Alenka z Říše div"/><Run Language="cs-cz" Text="ů"/><Run Text=" prodává nějaké vybavení, co by se ti mohlo hodit. Koukni se do u, měla by tam být."/></TextBlock>
        <Button HorizontalAlignment="Left" Margin="10,10,0,0" VerticalAlignment="Top" Height="95" Width="97" Click="Get_home" BorderBrush="{x:Null}" Background="#FFD0D0D0" Opacity="0.7">
            <Image Height="90" Source="/fotky/home_button.png" Stretch="Fill" Width="90"/>
        </Button>

    </Grid>
</Page>
